{
  "name": "ott-backend-worker",
  "version": "1.0.0",
  "scripts": {
    "dev": "wrangler dev src/index.ts",
    "deploy": "wrangler deploy --minify src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply ott-db --local && wrangler d1 migrations apply ott-db --remote"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "drizzle-orm": "^0.39.0",
    "jose": "^5.9.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "drizzle-kit": "^0.31.0",
    "wrangler": "^3.91.0",
    "typescript": "^5.7.2"
  }
}
