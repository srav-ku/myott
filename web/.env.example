# Local development environment variables.
# Copy to `.env.local` and fill in values.

# TMDB API key (v3) — required for fetching metadata.
TMDB_API_KEY=

# URL of the Cloudflare Worker that resolves embed/player URLs to direct stream URLs.
# Should expose POST /extract returning { url: string }.
EXTRACTOR_URL=

# Local SQLite path used in `next dev` mode (mirrors D1 schema).
LOCAL_DB_PATH=./local.db

# How long extracted stream URLs are considered valid (in seconds). Default 6 hours.
EXTRACT_TTL_SECONDS=21600
